APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ASSET_URL=                           # set to https://yourdomain.com in production

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false                # set to true in production
SESSION_SECURE_COOKIE=false          # set to true in production (HTTPS only)
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null                  # set to your domain in production

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_   # Get from Stripe Dashboard → Webhooks → signing secret

AT_USERNAME=                   # Africa's Talking username
AT_API_KEY=                    # Africa's Talking API key
AT_FROM=                       # Sender ID registered with Africa's Talking

FLUTTERWAVE_PUBLIC_KEY=        # Flutterwave dashboard → API Keys
FLUTTERWAVE_SECRET_KEY=        # Flutterwave dashboard → API Keys
FLUTTERWAVE_WEBHOOK_SECRET=    # Flutterwave dashboard → Webhooks → secret hash

QB_CLIENT_ID=                  # QuickBooks app → Keys & OAuth
QB_CLIENT_SECRET=              # QuickBooks app → Keys & OAuth
QB_REDIRECT_URI=               # e.g. https://yourdomain.com/admin/quickbooks/callback
QB_SANDBOX=false               # Set to true while testing against QB sandbox

VITE_APP_NAME="${APP_NAME}"
